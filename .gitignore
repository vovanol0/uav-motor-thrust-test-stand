# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# IDE / editor settings
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs and generated test data
logs/
uav_thrust_logs/
*.log

# Large raw measurement files
*.csv
*.txt

# But allow example logs if you want to publish demo data
!examples/**/*.csv
!examples/**/*.txt

# Temporary files
tmp/
temp/
*.tmp

# Build / packaging
build/
dist/
*.egg-info/

# Arduino build artifacts
*.hex
*.elf
*.bin
*.map

# Secrets / local config
.env
config.local.*
